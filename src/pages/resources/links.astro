---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Callout from '../../components/Callout.astro';
---

<DocsLayout title="Liens Utiles">
  <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
    Liens Utiles
  </h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
    Liste complète des ressources officielles pour chaque technologie du stack
  </p>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Astro
    </h2>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href="https://docs.astro.build"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Documentation Officielle</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Guide complet et référence API
        </p>
      </a>

      <a
        href="https://docs.astro.build/en/concepts/islands/"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Islands Architecture</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Concept des Islands et hydratation partielle
        </p>
      </a>

      <a
        href="https://docs.astro.build/en/guides/routing/"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Routing</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Routes dynamiques et paramètres
        </p>
      </a>

      <a
        href="https://docs.astro.build/en/guides/endpoints/"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">API Endpoints</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Créer des API routes
        </p>
      </a>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Preact & Signals
    </h2>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href="https://preactjs.com"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Documentation Preact</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Guide et API reference
        </p>
      </a>

      <a
        href="https://preactjs.com/guide/v10/signals"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Signals Guide</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          State management avec Signals
        </p>
      </a>

      <a
        href="https://preactjs.com/guide/v10/hooks"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Hooks</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          useState, useEffect, useRef, etc.
        </p>
      </a>

      <a
        href="https://preactjs.com/guide/v10/typescript"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">TypeScript</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Typage des composants Preact
        </p>
      </a>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      CommerceTools
    </h2>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href="https://docs.commercetools.com"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Documentation</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Documentation complète CommerceTools
        </p>
      </a>

      <a
        href="https://docs.commercetools.com/api"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">API Reference</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Référence complète de l'API
        </p>
      </a>

      <a
        href="https://docs.commercetools.com/api/projects/products"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Products API</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Gestion du catalogue produits
        </p>
      </a>

      <a
        href="https://docs.commercetools.com/api/projects/carts"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Carts API</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Gestion du panier
        </p>
      </a>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Contentstack
    </h2>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href="https://www.contentstack.com/docs"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Documentation</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Documentation complète Contentstack
        </p>
      </a>

      <a
        href="https://www.contentstack.com/docs/developers/apis/content-delivery-api"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Content Delivery API</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          API pour récupérer le contenu
        </p>
      </a>

      <a
        href="https://www.contentstack.com/docs/developers/live-preview"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Live Preview</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Édition en temps réel dans le Visual Builder
        </p>
      </a>

      <a
        href="https://www.contentstack.com/docs/developers/cli"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">CLI</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Import/export et gestion du contenu
        </p>
      </a>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Tailwind CSS
    </h2>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href="https://tailwindcss.com"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Documentation</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Documentation complète et référence
        </p>
      </a>

      <a
        href="https://tailwindcss.com/docs/upgrade-guide"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Guide de Migration v4</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Nouveautés et breaking changes
        </p>
      </a>

      <a
        href="https://tailwindcss.com/docs/utility-first"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Utility-First</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Philosophie et avantages
        </p>
      </a>

      <a
        href="https://tailwindcss.com/docs/responsive-design"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Responsive Design</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Breakpoints et mobile-first
        </p>
      </a>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      TypeScript
    </h2>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href="https://www.typescriptlang.org/docs/"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Documentation</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Documentation officielle TypeScript
        </p>
      </a>

      <a
        href="https://www.typescriptlang.org/cheatsheets"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Cheatsheets</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Antisèches par sujet
        </p>
      </a>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Outils & Communauté
    </h2>

    <div class="grid md:grid-cols-2 gap-4">
      <a
        href="https://github.com"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">GitHub</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Plateforme de code source
        </p>
      </a>

      <a
        href="https://code.visualstudio.com"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">VS Code</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Éditeur de code recommandé
        </p>
      </a>

      <a
        href="https://marketplace.visualstudio.com/items?itemName=astro-build.astro-vscode"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Astro Extension</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Extension VS Code pour Astro
        </p>
      </a>

      <a
        href="https://marketplace.visualstudio.com/items?itemName=bradlc.vscode-tailwindcss"
        target="_blank"
        class="p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
      >
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-semibold text-gray-900 dark:text-white">Tailwind Extension</h3>
          <span class="text-gray-400">↗</span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          Autocomplétion Tailwind CSS
        </p>
      </a>
    </div>
  </section>

  <Callout type="info">
    Ces liens sont les ressources officielles. N'hésitez pas à les consulter pour approfondir vos connaissances.
  </Callout>

  <!-- Navigation -->
  <div class="flex gap-4 pt-8 border-t border-gray-200 dark:border-gray-700">
    <a
      href="/examples/api-routes"
      class="flex-1 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
    >
      <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">← Précédent</div>
      <div class="font-semibold text-gray-900 dark:text-white">API Routes</div>
    </a>
    <a
      href="/resources/commands"
      class="flex-1 p-4 bg-purple-50 dark:bg-purple-900/20 rounded-lg border border-purple-200 dark:border-purple-800 hover:border-purple-500 transition-colors"
    >
      <div class="text-sm text-purple-600 dark:text-purple-400 mb-1">Suivant</div>
      <div class="font-semibold text-gray-900 dark:text-white">Commandes →</div>
    </a>
  </div>
</DocsLayout>
