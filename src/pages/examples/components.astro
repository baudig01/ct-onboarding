---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Callout from '../../components/Callout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
---

<DocsLayout title="Exemples de Composants">
  <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
    Exemples de Composants Astro
  </h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
    Patterns de composants Astro et Islands Preact avec exemples concrets
  </p>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Composant Astro Statique
    </h2>

    <Callout type="info">
      Les composants Astro (.astro) génèrent du HTML statique sans JavaScript côté client.
    </Callout>

    <div class="mt-6 space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">
          Card Produit Statique
        </h3>
        <CodeBlock
          title="components/ProductCard.astro"
          lang="astro"
          code={`---
interface Props {
  id: string;
  name: string;
  price: number;
  imageUrl: string;
  href: string;
}

const { id, name, price, imageUrl, href } = Astro.props;
---

<a
  href={href}
  class="block bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-lg transition-shadow"
>
  <div class="aspect-square overflow-hidden">
    <img
      src={imageUrl}
      alt={name}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
  </div>

  <div class="p-4">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 line-clamp-2">
      {name}
    </h3>
    <p class="text-xl font-bold text-purple-600">
      {price}€
    </p>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>`}
        />

        <div class="mt-4">
          <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Utilisation :</h4>
          <CodeBlock
            title="pages/category/[slug].astro"
            lang="astro"
            code={`---
import ProductCard from "../../components/ProductCard.astro";
import { getProducts } from "../../lib/services/product.service";

const products = await getProducts();
---

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
  {products.map(product => (
    <ProductCard
      id={product.id}
      name={product.name}
      price={product.price}
      imageUrl={product.images[0]}
      href={\`/product/\${product.id}\`}
    />
  ))}
</div>`}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Island Preact Simple
    </h2>

    <Callout type="success">
      Les Islands (.tsx) ajoutent de l'interactivité JavaScript uniquement là où c'est nécessaire.
    </Callout>

    <div class="mt-6 space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">
          Bouton Ajouter au Panier
        </h3>
        <CodeBlock
          title="features/cart/AddToCartButton.tsx"
          lang="tsx"
          code={`import { useState } from "preact/hooks";
import { addToCart } from "../../lib/signals/cart.store";

interface Props {
  productId: string;
  variantId: string;
  quantity?: number;
}

export function AddToCartButton({ productId, variantId, quantity = 1 }: Props) {
  const [loading, setLoading] = useState(false);
  const [success, setSuccess] = useState(false);

  const handleClick = async () => {
    setLoading(true);

    try {
      const result = await addToCart({ productId, variantId, quantity });

      if (result) {
        setSuccess(true);
        setTimeout(() => setSuccess(false), 2000);
      }
    } catch (error) {
      console.error("Add to cart failed:", error);
    } finally {
      setLoading(false);
    }
  };

  return (
    <button
      onClick={handleClick}
      disabled={loading}
      class={\`
        w-full px-6 py-3 rounded-lg font-semibold transition-all
        \${success
          ? "bg-green-600 text-white"
          : "bg-purple-600 hover:bg-purple-700 text-white"
        }
        disabled:opacity-50 disabled:cursor-not-allowed
      \`}
    >
      {loading && "Ajout en cours..."}
      {success && "✓ Ajouté au panier"}
      {!loading && !success && "Ajouter au panier"}
    </button>
  );
}`}
        />

        <div class="mt-4">
          <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Utilisation dans une page :</h4>
          <CodeBlock
            title="pages/product/[id].astro"
            lang="astro"
            code={`---
import { AddToCartButton } from "../../features/cart/AddToCartButton";
import { getProduct } from "../../lib/services/product.service";

const product = await getProduct(Astro.params.id);
---

<div class="product-page">
  <h1>{product.name}</h1>
  <p>{product.price}€</p>

  <!-- Island : hydraté immédiatement -->
  <AddToCartButton
    productId={product.id}
    variantId={product.masterVariant.id}
    client:load
  />
</div>`}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Island avec State Management
    </h2>

    <div class="space-y-6">
      <div>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">
          Mini Cart (Badge + Dropdown)
        </h3>
        <CodeBlock
          title="features/cart/MiniCart.tsx"
          lang="tsx"
          code={`import { useState } from "preact/hooks";
import { cart, totalQuantity } from "../../lib/signals/cart.store";

export function MiniCart() {
  const [isOpen, setIsOpen] = useState(false);

  return (
    <div class="relative">
      {/* Badge */}
      <button
        onClick={() => setIsOpen(!isOpen)}
        class="relative p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>

        {/* Badge count */}
        {totalQuantity.value > 0 && (
          <span class="absolute -top-1 -right-1 bg-purple-600 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">
            {totalQuantity.value}
          </span>
        )}
      </button>

      {/* Dropdown */}
      {isOpen && (
        <div class="absolute right-0 top-full mt-2 w-80 bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 z-50">
          <div class="p-4">
            <h3 class="text-lg font-semibold mb-4">Mon Panier</h3>

            {cart.value?.items.length === 0 ? (
              <p class="text-gray-500 text-center py-8">
                Votre panier est vide
              </p>
            ) : (
              <>
                <div class="space-y-4 mb-4">
                  {cart.value?.items.map((item) => (
                    <div key={item.id} class="flex gap-3">
                      <img
                        src={item.imageUrl}
                        alt={item.name}
                        class="w-16 h-16 object-cover rounded"
                      />
                      <div class="flex-1">
                        <p class="text-sm font-medium">{item.name}</p>
                        <p class="text-sm text-gray-500">
                          Qté: {item.quantity}
                        </p>
                        <p class="text-sm font-bold text-purple-600">
                          {item.price}€
                        </p>
                      </div>
                    </div>
                  ))}
                </div>

                <div class="border-t border-gray-200 dark:border-gray-700 pt-4">
                  <div class="flex justify-between mb-4">
                    <span class="font-semibold">Total</span>
                    <span class="font-bold text-lg">
                      {cart.value?.totalPrice}€
                    </span>
                  </div>

                  <a
                    href="/cart"
                    class="block w-full px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-center rounded-lg font-semibold transition-colors"
                  >
                    Voir le panier
                  </a>
                </div>
              </>
            )}
          </div>
        </div>
      )}
    </div>
  );
}`}
        />
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Galerie d'Images Interactive
    </h2>

    <CodeBlock
      title="features/product/ProductGallery.tsx"
      lang="tsx"
      code={`import { useState } from "preact/hooks";

interface Props {
  images: string[];
}

export function ProductGallery({ images }: Props) {
  const [selectedIndex, setSelectedIndex] = useState(0);

  return (
    <div class="space-y-4">
      {/* Image principale */}
      <div class="aspect-square bg-gray-100 dark:bg-gray-800 rounded-lg overflow-hidden">
        <img
          src={images[selectedIndex]}
          alt={\`Product image \${selectedIndex + 1}\`}
          class="w-full h-full object-cover"
        />
      </div>

      {/* Thumbnails */}
      <div class="grid grid-cols-4 gap-2">
        {images.map((image, index) => (
          <button
            key={index}
            onClick={() => setSelectedIndex(index)}
            class={\`
              aspect-square rounded-lg overflow-hidden border-2 transition-all
              \${
                index === selectedIndex
                  ? "border-purple-600 scale-105"
                  : "border-gray-200 dark:border-gray-700 hover:border-gray-400"
              }
            \`}
          >
            <img
              src={image}
              alt={\`Thumbnail \${index + 1}\`}
              class="w-full h-full object-cover"
            />
          </button>
        ))}
      </div>

      {/* Navigation arrows */}
      <div class="flex gap-2 justify-center">
        <button
          onClick={() => setSelectedIndex((prev) => Math.max(0, prev - 1))}
          disabled={selectedIndex === 0}
          class="px-4 py-2 bg-gray-100 dark:bg-gray-800 rounded-lg disabled:opacity-50"
        >
          ← Précédent
        </button>
        <button
          onClick={() => setSelectedIndex((prev) => Math.min(images.length - 1, prev + 1))}
          disabled={selectedIndex === images.length - 1}
          class="px-4 py-2 bg-gray-100 dark:bg-gray-800 rounded-lg disabled:opacity-50"
        >
          Suivant →
        </button>
      </div>
    </div>
  );
}`}
    />

    <div class="mt-4">
      <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Utilisation avec stratégie d'hydratation :</h4>
      <CodeBlock
        lang="astro"
        code={`<ProductGallery
  images={product.images}
  client:visible  {/* Hydraté quand visible dans le viewport */}
/>`}
      />
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Formulaire avec Validation
    </h2>

    <CodeBlock
      title="features/newsletter/NewsletterForm.tsx"
      lang="tsx"
      code={`import { useState } from "preact/hooks";

export function NewsletterForm() {
  const [email, setEmail] = useState("");
  const [loading, setLoading] = useState(false);
  const [success, setSuccess] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const validateEmail = (email: string) => {
    return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);
  };

  const handleSubmit = async (e: Event) => {
    e.preventDefault();
    setError(null);

    if (!validateEmail(email)) {
      setError("Email invalide");
      return;
    }

    setLoading(true);

    try {
      const res = await fetch("/api/newsletter/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      if (!res.ok) {
        throw new Error("Subscription failed");
      }

      setSuccess(true);
      setEmail("");
    } catch (err) {
      setError("Une erreur est survenue");
    } finally {
      setLoading(false);
    }
  };

  if (success) {
    return (
      <div class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-800 dark:text-green-200">
        ✓ Inscription réussie ! Vérifiez votre email.
      </div>
    );
  }

  return (
    <form onSubmit={handleSubmit} class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          Adresse email
        </label>
        <input
          type="email"
          value={email}
          onInput={(e) => setEmail((e.target as HTMLInputElement).value)}
          placeholder="votre@email.com"
          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-purple-500 focus:border-transparent"
          required
        />
      </div>

      {error && (
        <p class="text-sm text-red-600 dark:text-red-400">{error}</p>
      )}

      <button
        type="submit"
        disabled={loading}
        class="w-full px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold transition-colors disabled:opacity-50"
      >
        {loading ? "Inscription..." : "S'inscrire"}
      </button>
    </form>
  );
}`}
    />
  </section>

  <section class="mb-12">
    <Callout type="info">
      Pour le détail des stratégies d'hydratation (<code>client:load</code>, <code>client:visible</code>, <code>client:idle</code>, <code>client:media</code>), voir la page <a href="/architecture/islands" class="text-purple-600 dark:text-purple-400 underline hover:text-purple-800 dark:hover:text-purple-300">Islands Architecture</a>.
    </Callout>
  </section>

  <!-- Navigation -->
  <div class="flex gap-4 pt-8 border-t border-gray-200 dark:border-gray-700">
    <a
      href="/guides/methodology"
      class="flex-1 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 transition-colors"
    >
      <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">← Précédent</div>
      <div class="font-semibold text-gray-900 dark:text-white">Méthodologie</div>
    </a>
    <a
      href="/examples/signals"
      class="flex-1 p-4 bg-purple-50 dark:bg-purple-900/20 rounded-lg border border-purple-200 dark:border-purple-800 hover:border-purple-500 transition-colors"
    >
      <div class="text-sm text-purple-600 dark:text-purple-400 mb-1">Suivant</div>
      <div class="font-semibold text-gray-900 dark:text-white">Signals Stores →</div>
    </a>
  </div>
</DocsLayout>
