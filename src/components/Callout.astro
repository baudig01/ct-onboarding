---
interface Props {
  type?: 'info' | 'warning' | 'success' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800',
  warning: 'bg-yellow-50 dark:bg-yellow-900/20 border-yellow-200 dark:border-yellow-800',
  success: 'bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800',
  danger: 'bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800'
};

const icons = {
  info: 'ℹ️',
  warning: '⚠️',
  success: '✅',
  danger: '❌'
};

const textColors = {
  info: 'text-blue-900 dark:text-blue-100',
  warning: 'text-yellow-900 dark:text-yellow-100',
  success: 'text-green-900 dark:text-green-100',
  danger: 'text-red-900 dark:text-red-100'
};
---

<div class={`callout p-4 rounded-lg border ${styles[type]} ${textColors[type]} my-4`}>
  <div class="flex gap-3">
    <span class="text-xl flex-shrink-0">{icons[type]}</span>
    <div class="flex-1">
      {title && <div class="font-semibold mb-1">{title}</div>}
      <div class="text-sm">
        <slot />
      </div>
    </div>
  </div>
</div>
